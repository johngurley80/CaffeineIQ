{
  "$schema": "https://design-tokens.org/schema",
  "meta": {
    "name": "CaffeineIQ",
    "version": "1.0.0",
    "description": "Approved tokens for CaffeineIQ — cream + espresso palette",
    "source": "CaffeineIQ Homepage v5.html"
  },
  "colors": {
    "background": "#faf7f2",
    "surface": "#ffffff",
    "surface-muted": "#f5f1ea",
    "border": "#e8e0d5",
    "border-strong": "#d8cdbe",
    "accent": "#3d1f0d",
    "accent-hover": "#26120a",
    "accent-dim": "rgba(61, 31, 13, 0.10)",
    "accent-soft": "rgba(61, 31, 13, 0.05)",
    "ink": "#1e2d4a",
    "ink-dim": "rgba(30, 45, 74, 0.08)",
    "warning": "#c4622d",
    "warning-dim": "rgba(196, 98, 45, 0.10)",
    "danger": "#c4622d",
    "danger-dim": "rgba(196, 98, 45, 0.14)",
    "text-primary": "#1e2d4a",
    "text-secondary": "#6b6b6b",
    "text-tertiary": "#a8a29e",
    "text-on-accent": "#faf7f2"
  },
  "typography": {
    "fontFamily": {
      "display": "'Instrument Serif', Georgia, serif",
      "ui": "'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif",
      "mono": "'IBM Plex Mono', ui-monospace, monospace"
    },
    "fontSize": {
      "xs": "11px",
      "sm": "12px",
      "body": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "22px",
      "2xl": "28px",
      "3xl": "32px",
      "card-number": "64px",
      "card-number-time": "56px",
      "section-title": "clamp(34px, 4.2vw, 48px)",
      "headline": "clamp(40px, 6vw, 76px)",
      "subheadline": "clamp(16px, 1.6vw, 19px)"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 0.95,
      "snug": 1.05,
      "normal": 1.4,
      "relaxed": 1.55,
      "loose": 1.6
    },
    "letterSpacing": {
      "tighter": "-0.04em",
      "tight": "-0.025em",
      "snug": "-0.015em",
      "normal": "0",
      "wide": "0.02em",
      "wider": "0.04em",
      "widest": "0.16em"
    },
    "textTransform": {
      "label": "uppercase"
    }
  },
  "spacing": {
    "0": "0",
    "1": "4px",
    "2": "6px",
    "3": "8px",
    "4": "10px",
    "5": "12px",
    "6": "14px",
    "7": "16px",
    "8": "18px",
    "9": "22px",
    "10": "24px",
    "11": "28px",
    "12": "32px",
    "section-y": "96px",
    "section-y-mobile": "64px",
    "hero-y": "88px",
    "hero-y-mobile": "56px",
    "wrap-x": "28px",
    "wrap-x-mobile": "18px",
    "wrap-max": "1200px"
  },
  "borderRadius": {
    "xs": "8px",
    "sm": "10px",
    "md": "12px",
    "lg": "14px",
    "xl": "16px",
    "2xl": "18px",
    "3xl": "20px",
    "pill": "999px"
  },
  "borderWidth": {
    "default": "1px",
    "thick": "3px"
  },
  "shadow": {
    "none": "none",
    "xs": "0 1px 2px rgba(28,25,23,0.025)",
    "sm": "0 1px 2px rgba(28,25,23,0.025), 0 8px 24px -16px rgba(28,25,23,0.08)",
    "thumb": "0 1px 2px rgba(28,25,23,0.12), 0 0 0 4px rgba(30,45,74,0.12)"
  },
  "transition": {
    "fast": "0.12s ease",
    "default": "0.18s ease",
    "slow": "0.35s ease"
  },
  "breakpoints": {
    "sm": "520px",
    "md": "720px",
    "tool-grid": "760px",
    "lg": "820px",
    "xl": "980px",
    "wrap": "1200px"
  }
}